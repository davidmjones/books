\NeedsTeXFormat{LaTeX2e}[2005/12/01]
\ProvidesPackage{amsviet}[2008/04/17 v1.00 Vietnamese alphabet support]
\RequirePackage{dblaccnt}
\let\vntex@DeclareTextDoubleComposite\DeclareTextDoubleComposite

\def\DeclareTextDoubleComposite#1#2#3#4#5{%
    \vntex@DeclareTextDoubleComposite{#1}{#2}{#3}{#4}{#5}%
    \vntex@DeclareTextDoubleComposite{#3}{#2}{#1}{#4}{#5}%
}
\RequirePackage[T5,\encodingdefault]{fontenc}
\providecommand\vietrmdefault{lmr}
\providecommand\vietsfdefault{lmss}
\providecommand\vietttdefault{lmtt}
\DeclareFontSubstitution{T5}{\vietrmdefault}{m}{n}
\DeclareRobustCommand\vietenc{%
    \not@math@alphabet\vietenc\relax
    \fontencoding{T5}%
    \long\edef\f@family{\f@family}%
    \long\edef\sfdefault{\sfdefault}%
    \long\edef\ttdefault{\ttdefault}%
    \ifx\f@family\sfdefault
        \fontfamily\vietsfdefault
    \else\ifx\f@family\ttdefault
        \fontfamily\vietttdefault
    \else
        \fontfamily\vietrmdefault
    \fi\fi
    \selectfont
}
\DeclareTextFontCommand{\textviet}{\vietenc}
